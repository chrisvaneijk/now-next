---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Services from '../components/Services.astro';
import Manifesto from '../components/Manifesto.astro';
import About from '../components/About.astro';
import Process from '../components/Process.astro';
import Articles from '../components/Articles.astro';
import Cta from '../components/Cta.astro';
import Footer from '../components/Footer.astro';

const lang = 'nl' as const;
---

<Layout
  lang={lang}
  title="now→next — AI App Ontwikkeling, Digitale Transformatie & SAFe Agile · Nederland"
  description="Senior freelance tech consultant. Ik bouw moderne apps met AI coding teams, leid digitale transformatieprogramma's en drive SAFe agile transformaties. Gevestigd in Voorburg, NL."
>
  <Nav lang={lang} />
  <Hero lang={lang} />
  <Marquee lang={lang} />
  <Services lang={lang} />
  <Manifesto lang={lang} />
  <About lang={lang} />
  <Process lang={lang} />
  <Articles lang={lang} />
  <Cta lang={lang} />
  <Footer lang={lang} />
</Layout>
