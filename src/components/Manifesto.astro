---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'nl' } = Astro.props;
const m = translations[lang].manifesto;
---

<section id="manifesto" aria-label={lang === 'nl' ? 'Filosofie' : 'Philosophy'}>
  <div class="glow" aria-hidden="true"></div>
  <div class="body">
    <p class="s-label rv" style="margin-bottom:2.25rem;">{m.label}</p>
    <blockquote class="manifesto-q rv">
      <Fragment set:html={m.quote} />
    </blockquote>

    <div class="pillars">
      {m.pillars.map((p, i) => (
        <div class={`rv${i > 0 ? ` rv-d${i}` : ''}`}>
          <p class="pillar-label">{p.label}</p>
          <p class="pillar-text">{p.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding: 10rem 3.5rem;
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(201,104,16,.05) 0%, transparent 65%);
  }

  .body { position: relative; max-width: 1000px; }

  .manifesto-q {
    font-family: var(--f-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.7rem, 3.2vw, 2.8rem);
    letter-spacing: -.01em;
    line-height: 1.35;
    margin-bottom: 4rem;
  }
  .manifesto-q :global(em) { font-style: normal; color: var(--accent); }

  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }

  .pillar-label {
    font-family: var(--f-mono);
    font-size: .6rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: .85rem;
  }

  .pillar-text {
    font-size: .9rem;
    color: var(--text-dim);
    line-height: 1.72;
  }

  @media (max-width: 960px) {
    section { padding: 5rem 1.75rem; }
    .pillars { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
