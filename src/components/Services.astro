---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'nl' } = Astro.props;
const s = translations[lang].services;

const icons = [
  `<svg class="svc-icon" viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="7" width="30" height="22" rx="2"/><path d="M12 15l-4 4 4 4M24 15l4 4-4 4M18 12l-3 12"/></svg>`,
  `<svg class="svc-icon" viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="18" r="12"/><circle cx="18" cy="18" r="4"/><path d="M18 6v4M18 26v4M6 18h4M26 18h4"/><path d="M10 10l3 3M23 23l3 3M23 10l3-3M10 23l-3 3"/></svg>`,
  `<svg class="svc-icon" viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 4L4 14v18h9v-8h10v8h9V14L18 4z"/><rect x="14" y="24" width="8" height="8"/><path d="M10 20h4M22 20h4M18 14v6"/></svg>`,
];
const nums = ['01', '02', '03'];
---

<section id="services" aria-label="Services">
  <div class="s-header rv">
    <div class="s-header-left">
      <p class="s-label">{s.label}</p>
      <h2 class="s-title">{s.title[0]}<br>{s.title[1]}</h2>
    </div>
    <p class="s-header-right">{s.right}</p>
  </div>

  <div class="svcs-grid">
    {s.items.map((svc, i) => (
      <article class={`svc rv${i > 0 ? ` rv-d${i}` : ''}`}>
        <div class="svc-num" aria-hidden="true">{nums[i]}</div>
        <Fragment set:html={icons[i]} />
        <h3 class="svc-name">{svc.name}</h3>
        <p class="svc-desc">{svc.desc}</p>
        <ul class="svc-tags" role="list" aria-label="Related skills">
          {svc.tags.map(tag => <li><span class="tag">{tag}</span></li>)}
        </ul>
      </article>
    ))}
  </div>
</section>

<style>
  section {
    padding: 8rem 3.5rem;
    border-top: 1px solid var(--border);
  }

  .svcs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .svc {
    padding: 3rem 2.75rem;
    border-right: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    transition: background .45s;
  }
  .svc:last-child { border-right: none; }

  .svc::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .4s cubic-bezier(.22,1,.36,1);
  }
  .svc:hover::after { transform: scaleX(1); }
  .svc:hover { background: rgba(201,104,16,.04); }

  .svc-num {
    font-family: var(--f-display);
    font-weight: 800;
    font-size: 5.5rem;
    line-height: 1;
    letter-spacing: -.06em;
    color: rgba(28,24,20,.05);
    margin-bottom: 1.75rem;
    transition: color .4s;
    user-select: none;
  }
  .svc:hover .svc-num { color: rgba(201,104,16,.18); }

  :global(.svc-icon) {
    width: 36px; height: 36px;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .svc-name {
    font-family: var(--f-body);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -.02em;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .svc-desc {
    font-size: .9rem;
    color: var(--text-dim);
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .svc-tags {
    display: flex; flex-wrap: wrap; gap: .35rem;
    list-style: none;
  }
  .svc:hover .tag { border-color: var(--border-2); color: var(--text-dim); }

  @media (max-width: 960px) {
    section { padding: 5rem 1.75rem; }
    .svcs-grid { grid-template-columns: 1fr; }
    .svc { border-right: none; border-bottom: 1px solid var(--border); }
    .svc:last-child { border-bottom: none; }
    .s-header { flex-direction: column; align-items: flex-start; }
    .s-header-right { text-align: left; max-width: none; }
  }
</style>
