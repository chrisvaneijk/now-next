---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'nl' } = Astro.props;
const p = translations[lang].process;
---

<section id="process" aria-label={lang === 'nl' ? 'Hoe het werkt' : 'How it works'}>
  <div class="s-header rv">
    <div class="s-header-left">
      <p class="s-label">{p.label}</p>
      <h2 class="s-title">{p.title[0]}<br>{p.title[1]}</h2>
    </div>
  </div>

  <ol class="steps" role="list">
    {p.steps.map((step, i) => (
      <li class={`step rv${i > 0 ? ` rv-d${i}` : ''}`}>
        <div class="step-n">{step.num}</div>
        <h3 class="step-title">{step.title}</h3>
        <p class="step-desc">{step.desc}</p>
      </li>
    ))}
  </ol>
</section>

<style>
  section {
    padding: 8rem 3.5rem;
    border-bottom: 1px solid var(--border);
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    list-style: none;
  }

  .step {
    padding: 2.25rem 2.5rem;
    border-left: 1px solid var(--border);
  }
  .step:first-child { border-left: none; padding-left: 0; }

  .step-n {
    font-family: var(--f-mono);
    font-size: .58rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.35rem;
  }

  .step-title {
    font-family: var(--f-body);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -.02em;
    margin-bottom: .75rem;
  }

  .step-desc {
    font-size: .85rem;
    color: var(--text-dim);
    line-height: 1.7;
  }

  @media (max-width: 960px) {
    section { padding: 5rem 1.75rem; }
    .steps { grid-template-columns: 1fr 1fr; }
    .step:nth-child(odd)  { border-left: none; padding-left: 0; }
    .step:nth-child(3),
    .step:nth-child(4)    { padding-top: 2.25rem; border-top: 1px solid var(--border); }
  }
</style>
