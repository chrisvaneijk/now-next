---
---

<section id="contact" aria-label="Contact">
  <div class="glow" aria-hidden="true"></div>
  <div class="inner">
    <p class="cta-label rv">Let's talk</p>
    <h2 class="cta-h2 rv">
      Let's go from<br>now to next.
    </h2>
    <p class="cta-sub rv">
      One conversation is enough to know if we're a fit.
      Tell me where you want to go — I'll tell you how fast we can get there.
    </p>
    <div class="cta-row rv">
      <a href="mailto:info@now-next.nl" class="btn-primary">Start the conversation →</a>
      <a href="mailto:info@now-next.nl" class="cta-mail">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="M2 8l10 6 10-6"/>
        </svg>
        info@now-next.nl
      </a>
    </div>
  </div>
</section>

<style>
  section {
    padding: 11rem 3.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
  }

  .glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 65% 55% at 50% 50%, rgba(201,104,16,.06) 0%, transparent 65%);
  }

  .inner { position: relative; }

  .cta-label {
    font-family: var(--f-mono);
    font-size: .6rem;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 2rem;
    display: inline-flex; align-items: center; gap: 1rem;
  }
  .cta-label::before, .cta-label::after {
    content: ''; width: 1.75rem; height: 1px; background: var(--accent);
  }

  .cta-h2 {
    font-family: var(--f-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(2.8rem, 7vw, 6rem);
    letter-spacing: -.01em;
    line-height: .95;
    margin-bottom: 1.5rem;
  }

  .cta-sub {
    font-size: 1rem;
    color: var(--text-dim);
    max-width: 38ch;
    margin: 0 auto 3.5rem;
    line-height: 1.7;
  }

  .cta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    flex-wrap: wrap;
  }

  .cta-mail {
    font-family: var(--f-mono);
    font-size: .75rem;
    letter-spacing: .08em;
    color: var(--text-dim);
    text-decoration: none;
    display: inline-flex; align-items: center; gap: .5rem;
    transition: color .2s;
  }
  .cta-mail:hover { color: var(--text); }

  @media (max-width: 960px) {
    section { padding: 6rem 1.75rem; }
  }
</style>
