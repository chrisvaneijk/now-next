---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'nl' } = Astro.props;
const n = translations[lang].nav;
---

<nav>
  <a href={lang === 'nl' ? '/#home' : '/en/#home'} class="nav-logo">now<span class="arr">→</span>next</a>
  <ul class="nav-links" role="list">
    <li><a href="#services">{n.services}</a></li>
    <li><a href="#about">{n.about}</a></li>
    <li><a href="#process">{n.process}</a></li>
  </ul>
  <div class="nav-right">
    <a href={n.langSwitchHref} class="lang-switch">{n.langSwitch}</a>
    <a href="#contact" class="nav-btn">{n.cta}</a>
  </div>
</nav>

<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.75rem 3.5rem;
    background: linear-gradient(to bottom, rgba(240,232,220,.95) 50%, transparent);
  }

  .nav-logo {
    font-family: var(--f-body);
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: -.02em;
    color: var(--text);
    text-decoration: none;
  }
  .nav-logo .arr { color: var(--accent); }

  .nav-links {
    display: flex; gap: 2.75rem; list-style: none;
  }
  .nav-links a {
    font-family: var(--f-mono);
    font-size: .62rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--text); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .lang-switch {
    font-family: var(--f-mono);
    font-size: .62rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--text-mute);
    text-decoration: none;
    transition: color .2s, border-color .2s;
    border: 1px solid var(--border);
    padding: .4rem .7rem;
  }
  .lang-switch:hover { color: var(--text-dim); border-color: var(--border-2); }

  .nav-btn {
    font-family: var(--f-mono);
    font-size: .62rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--accent);
    padding: .65rem 1.5rem;
    text-decoration: none;
    font-weight: 700;
    transition: background .2s, transform .2s;
    white-space: nowrap;
  }
  .nav-btn:hover { background: #A85608; transform: translateY(-1px); }

  @media (max-width: 960px) {
    nav { padding: 1.5rem 1.75rem; }
    .nav-links { display: none; }
  }
</style>
