---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'nl' } = Astro.props;
const a = translations[lang].about;

const creds = [
  { badge: 'SPC4', name: 'Certified SAFe® Program Consultant', org: 'Scaled Agile' },
  { badge: 'PSM I', name: 'Professional Scrum Master', org: 'Scrum.org' },
  { badge: 'AC', name: 'Agile Coaching', org: 'ICAgile' },
  { badge: 'PO', name: 'Certified Product Owner', org: 'Agile Scrum Group' },
];
const statsNums = ['20', '3×', 'NL', '∅'];
---

<section id="about" aria-label={lang === 'nl' ? 'Over mij' : 'About'}>
  <div class="s-header rv" style="margin-bottom:0;padding-bottom:0;border-bottom:none;">
    <p class="s-label">{a.label}</p>
  </div>

  <div class="about-grid">
    <div class="about-left">
      <h2 class="about-h2 rv">
        {a.h2First}<br><em>{a.h2Second}</em>{a.h2Rest}
      </h2>
      <p class="about-p rv">{a.p1}</p>
      <p class="about-p rv">{a.p2}</p>
      <p class="about-p rv">{a.p3}</p>

      <ul class="creds rv" aria-label="Certifications">
        {creds.map(c => (
          <li class="cred">
            <span class="cred-badge">{c.badge}</span>
            <span class="cred-name">{c.name}</span>
            <span class="cred-org">{c.org}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="about-right rv rv-d1">
      <div class="stats">
        {statsNums.map((n, i) => (
          <div class="stat">
            <div class="stat-n"><span class="hi">{n}</span>{i === 0 ? '+' : ''}</div>
            <div class="stat-lbl">{a.statsLabels[i]}</div>
          </div>
        ))}
      </div>

      <blockquote class="testimonial rv rv-d2">
        <p>{a.quote}</p>
        <cite>{a.quoteBy}</cite>
      </blockquote>
    </div>
  </div>
</section>

<style>
  section {
    padding: 8rem 3.5rem;
    border-bottom: 1px solid var(--border);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 5fr 4fr;
    gap: 6rem;
    align-items: start;
    margin-top: 4rem;
  }

  .about-h2 {
    font-family: var(--f-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.9rem, 3.2vw, 2.7rem);
    letter-spacing: -.01em;
    line-height: 1.15;
    margin-bottom: 2rem;
  }
  .about-h2 em { font-style: normal; color: var(--accent); }

  .about-p {
    font-size: .95rem;
    color: var(--text-dim);
    line-height: 1.78;
    margin-bottom: 1.25rem;
  }

  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }

  .stat {
    background: var(--bg);
    padding: 2.25rem 2rem;
    position: relative;
    overflow: hidden;
    transition: background .3s;
  }
  .stat:hover { background: var(--bg-3); }
  .stat::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform .4s cubic-bezier(.22,1,.36,1);
  }
  .stat:hover::before { transform: scaleY(1); }

  .stat-n {
    font-family: var(--f-body);
    font-weight: 800;
    font-size: 2.6rem;
    letter-spacing: -.04em;
    line-height: 1;
    margin-bottom: .5rem;
  }
  .stat-n .hi { color: var(--accent); }

  .stat-lbl {
    font-family: var(--f-mono);
    font-size: .58rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--text-mute);
  }

  .creds {
    list-style: none;
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
  }

  .cred {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: .9rem 1.25rem;
    border-bottom: 1px solid var(--border);
    transition: background .2s;
  }
  .cred:last-child { border-bottom: none; }
  .cred:hover { background: var(--bg-2); }

  .cred-badge {
    font-family: var(--f-mono);
    font-size: .55rem;
    font-weight: 700;
    letter-spacing: .08em;
    color: var(--accent);
    border: 1px solid rgba(201,104,16,.35);
    padding: .2rem .5rem;
    min-width: 3rem;
    text-align: center;
    flex-shrink: 0;
  }

  .cred-name {
    font-family: var(--f-body);
    font-size: .82rem;
    font-weight: 500;
    color: var(--text);
    flex: 1;
  }

  .cred-org {
    font-family: var(--f-mono);
    font-size: .55rem;
    letter-spacing: .08em;
    color: var(--text-mute);
    white-space: nowrap;
  }

  .testimonial {
    margin-top: 2rem;
    padding: 1.5rem;
    border-left: 2px solid var(--accent);
    background: var(--bg-2);
  }
  .testimonial p {
    font-family: var(--f-display);
    font-style: italic;
    font-size: .95rem;
    color: var(--text-dim);
    line-height: 1.65;
    margin-bottom: .75rem;
  }
  .testimonial cite {
    font-family: var(--f-mono);
    font-size: .58rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text-mute);
    font-style: normal;
  }

  @media (max-width: 960px) {
    section { padding: 5rem 1.75rem; }
    .about-grid { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>
