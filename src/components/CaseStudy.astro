---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'nl' } = Astro.props;
const c = translations[lang].caseStudy;
---

<section id="case-study" aria-label="Case study">
  <div class="s-header rv">
    <div class="s-header-left">
      <p class="s-label">{c.label}</p>
      <h2 class="s-title">{c.title[0]}<br>{c.title[1]}</h2>
    </div>
    <p class="s-header-right">{c.desc}</p>
  </div>

  <div class="cs-grid">
    <!-- Screenshot -->
    <div class="cs-screen rv">
      <div class="screen-wrap">
        <img
          src="https://pilot-next.com/img/screenshots/home-dashboard-wide.webp"
          alt="pilot-next dashboard"
          class="screen-img"
          loading="lazy"
        />
      </div>
      <div class="screen-mobile">
        <img
          src="https://pilot-next.com/img/screenshots/schedule.webp"
          alt="pilot-next schedule on mobile"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Info -->
    <div class="cs-info">
      <!-- Tag + product name -->
      <div class="cs-meta rv">
        <span class="tag">{c.tag}</span>
        <a href="https://pilot-next.com" target="_blank" rel="noopener noreferrer" class="cs-link">
          pilot-next.com ↗
        </a>
      </div>

      <!-- Metrics -->
      <div class="cs-metrics rv rv-d1">
        {c.metrics.map(m => (
          <div class="cs-metric">
            <div class="cs-metric-val">{m.value}</div>
            <div class="cs-metric-lbl">{m.label}</div>
          </div>
        ))}
      </div>

      <!-- Features -->
      <ul class="cs-features rv rv-d2" role="list">
        {c.features.map(f => (
          <li>
            <span class="cs-check" aria-hidden="true">→</span>
            {f}
          </li>
        ))}
      </ul>

      <a href="https://pilot-next.com" target="_blank" rel="noopener noreferrer" class="btn-primary rv rv-d3">
        {c.cta}
      </a>
    </div>
  </div>
</section>

<style>
  section {
    padding: 8rem 3.5rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg-2);
  }

  .cs-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 5rem;
    align-items: start;
  }

  /* Screenshot */
  .cs-screen {
    position: relative;
  }

  .screen-wrap {
    border: 1px solid var(--border);
    overflow: hidden;
    background: var(--bg-3);
  }
  .screen-wrap img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform .6s cubic-bezier(.22,1,.36,1);
  }
  .screen-wrap:hover img { transform: scale(1.02); }

  .screen-mobile {
    position: absolute;
    bottom: calc(-2rem - 2cm);
    right: -1.5rem;
    width: 28%;
    max-height: none;
    border: 1px solid var(--border);
    background: var(--bg-3);
    box-shadow: 0 8px 32px rgba(28,24,20,.12);
    overflow: hidden;
  }
  .screen-mobile img {
    width: 102%;
    height: auto;
    display: block;
    margin-left: -1%;
  }

  /* Info */
  .cs-info {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-top: .5rem;
  }

  .cs-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .cs-link {
    font-family: var(--f-mono);
    font-size: .62rem;
    letter-spacing: .1em;
    color: var(--accent);
    text-decoration: none;
    transition: opacity .2s;
  }
  .cs-link:hover { opacity: .7; }

  .cs-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }

  .cs-metric {
    background: var(--bg);
    padding: 1.25rem 1.5rem;
  }

  .cs-metric-val {
    font-family: var(--f-body);
    font-weight: 800;
    font-size: 1.8rem;
    letter-spacing: -.04em;
    line-height: 1;
    color: var(--accent);
    margin-bottom: .35rem;
  }

  .cs-metric-lbl {
    font-family: var(--f-mono);
    font-size: .55rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text-mute);
  }

  .cs-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }

  .cs-features li {
    font-family: var(--f-body);
    font-size: .9rem;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: .75rem;
  }

  .cs-check {
    color: var(--accent);
    font-size: .75rem;
    flex-shrink: 0;
  }

  @media (max-width: 960px) {
    section { padding: 5rem 1.75rem; }
    .cs-grid { grid-template-columns: 1fr; gap: 3rem; }
    .screen-mobile {
      width: 40%;
      bottom: -1.5rem;
      right: -0.5rem;
      max-height: 14rem;
    }
    .s-header { flex-direction: column; align-items: flex-start; }
    .s-header-right { text-align: left; max-width: none; }
  }
</style>
