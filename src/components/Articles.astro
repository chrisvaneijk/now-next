---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'nl' } = Astro.props;
const ar = translations[lang].articles;

const articles = [
  {
    title: lang === 'nl'
      ? "Ik bouwde solo een SaaS-app met AI. Dit verraste me het meest."
      : "I Built a SaaS App Solo Using AI. Here's What Surprised Me Most.",
    date: "Jun 2025",
    url: "https://www.linkedin.com/in/chrisvaneijk/",
    tag: lang === 'nl' ? 'AI Ontwikkeling' : 'AI Development',
  },
  {
    title: lang === 'nl'
      ? "Hoe je Agile succesvol schaalt over meerdere teams met SAFe"
      : "How to Successfully Scale Agile Across Multiple Teams Using SAFe",
    date: "Jun 2024",
    url: "https://www.linkedin.com/in/chrisvaneijk/",
    tag: 'SAFe',
  },
  {
    title: lang === 'nl'
      ? "Top 3 Agile-metrics om teamgezondheid en voortgang bij te houden"
      : "Top 3 Agile Metrics to Track Team Health and Progress",
    date: "Nov 2024",
    url: "https://www.linkedin.com/in/chrisvaneijk/",
    tag: 'Agile',
  },
  {
    title: lang === 'nl'
      ? "De rol van leiderschap in agile transformatie"
      : "The Role of Leadership in Agile Transformation",
    date: "May 2024",
    url: "https://www.linkedin.com/in/chrisvaneijk/",
    tag: lang === 'nl' ? 'Leiderschap' : 'Leadership',
  },
];
---

<section id="articles" aria-label={lang === 'nl' ? 'Artikelen' : 'Articles'}>
  <div class="s-header rv">
    <div class="s-header-left">
      <p class="s-label">{ar.label}</p>
      <h2 class="s-title">{ar.title[0]}<br>{ar.title[1]}</h2>
    </div>
    <p class="s-header-right">{ar.right}</p>
  </div>

  <ul class="articles-list" role="list">
    {articles.map((a, i) => (
      <li class={`article rv${i > 0 ? ` rv-d${Math.min(i, 4)}` : ''}`}>
        <a href={a.url} target="_blank" rel="noopener noreferrer" class="article-link">
          <span class="article-tag">{a.tag}</span>
          <span class="article-title">{a.title}</span>
          <span class="article-meta">
            <span class="article-date">{a.date}</span>
            <span class="article-arrow" aria-hidden="true">→</span>
          </span>
        </a>
      </li>
    ))}
  </ul>

  <p class="articles-more rv">
    <a href="https://www.linkedin.com/in/chrisvaneijk/" target="_blank" rel="noopener noreferrer">
      {ar.more}
    </a>
  </p>
</section>

<style>
  section {
    padding: 8rem 3.5rem;
    border-top: 1px solid var(--border);
  }

  .articles-list {
    list-style: none;
    border-top: 1px solid var(--border);
  }

  .article {
    border-bottom: 1px solid var(--border);
  }

  .article-link {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 1.75rem 0;
    text-decoration: none;
  }
  .article-link:hover .article-title { color: var(--accent); }
  .article-link:hover .article-arrow { transform: translateX(4px); }

  .article-tag {
    font-family: var(--f-mono);
    font-size: .55rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid rgba(201,104,16,.3);
    padding: .25rem .6rem;
    white-space: nowrap;
    justify-self: start;
  }

  .article-title {
    font-family: var(--f-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
    transition: color .2s;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .article-date {
    font-family: var(--f-mono);
    font-size: .58rem;
    letter-spacing: .1em;
    color: var(--text-mute);
    white-space: nowrap;
  }

  .article-arrow {
    font-size: .9rem;
    color: var(--accent);
    transition: transform .2s;
    display: inline-block;
  }

  .articles-more {
    margin-top: 2.5rem;
  }
  .articles-more a {
    font-family: var(--f-mono);
    font-size: .62rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    transition: color .2s;
  }
  .articles-more a:hover { color: var(--accent); }

  @media (max-width: 960px) {
    section { padding: 5rem 1.75rem; }
    .article-link {
      grid-template-columns: 1fr;
      gap: .75rem;
    }
    .article-meta { justify-content: space-between; }
    .s-header { flex-direction: column; align-items: flex-start; }
    .s-header-right { text-align: left; max-width: none; }
  }
</style>
